# Copy this file to .env and fill only the values required by your setup.
# When this file exists, its values take precedence for the app and backend.

# Shared secret used by Electron to publish events to the standalone backend.
APP_INGEST_TOKEN=

# Standalone browser backend.
BROWSER_BACKEND_PORT=47831
BROWSER_BACKEND_DATA_DIR=

# Electron external-backend mode. Leave blank while using the embedded backend.
BROWSER_BACKEND_URL=
BROWSER_BACKEND_MODE=

# Google OAuth for verified local-chat identities.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Optional local gateway override.
VIEWER_GATEWAY_PORT=47831
